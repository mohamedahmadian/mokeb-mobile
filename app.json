{
  "expo": {
    "name": "موکب من",
    "slug": "mokeb-mobile",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mokeb",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8fafc"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mokeb.mobile",
      "infoPlist": {
        "ExpoLocalization_supportsRTL": true,
        "ExpoLocalization_forcesRTL": false,
        "CFBundleLocalizations": [
          "fa"
        ]
      }
    },
    "android": {
      "package": "com.mokeb.mobile",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#E8EEF6",
        "foregroundImage": "./assets/images/icon.png",
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "blockedPermissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "headers": {
            "Cross-Origin-Embedder-Policy": "credentialless",
            "Cross-Origin-Opener-Policy": "same-origin"
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#f8fafc",
          "imageWidth": 200
        }
      ],
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": [
              "fa"
            ],
            "android": [
              "fa"
            ]
          }
        }
      ],
      "expo-sharing",
      "expo-document-picker",
      [
        "expo-media-library",
        {
          "photosPermission": "برای ذخیره زائر کارت در گالری به دسترسی عکس‌ها نیاز است.",
          "savePhotosPermission": "برای ذخیره زائر کارت در گالری به دسترسی عکس‌ها نیاز است.",
          "granularPermissions": [
            "photo"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "برای انتخاب تصویر پروفایل و کارت ملی به دسترسی گالری نیاز است.",
          "cameraPermission": "برای گرفتن تصویر پروفایل و کارت ملی به دسترسی دوربین نیاز است.",
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supportsRTL": true,
      "forcesRTL": false,
      "guestBaseUrl": "",
      "router": {
        "headers": {
          "Cross-Origin-Embedder-Policy": "credentialless",
          "Cross-Origin-Opener-Policy": "same-origin"
        }
      },
      "eas": {
        "projectId": "22545750-a80b-4fc2-9a9c-b73bd9d73b17"
      }
    }
  }
}