{
  "expo": {
    "name": "موکب‌یار",
    "slug": "mokeb-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mokeb",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8fafc"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mokeb.mobile"
    },
    "android": {
      "package": "com.mokeb.mobile",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#E8EEF6",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "headers": {
            "Cross-Origin-Embedder-Policy": "credentialless",
            "Cross-Origin-Opener-Policy": "same-origin"
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "resizeMode": "contain",
          "backgroundColor": "#f8fafc",
          "imageWidth": 220
        }
      ],
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": [
              "fa"
            ],
            "android": [
              "fa"
            ]
          }
        }
      ],
      "expo-sharing",
      [
        "expo-media-library",
        {
          "photosPermission": "برای ذخیره زائر کارت در گالری به دسترسی عکس‌ها نیاز است.",
          "savePhotosPermission": "برای ذخیره زائر کارت در گالری به دسترسی عکس‌ها نیاز است.",
          "granularPermissions": [
            "photo"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "برای انتخاب تصویر پروفایل و کارت ملی به دسترسی گالری نیاز است.",
          "cameraPermission": "برای گرفتن تصویر پروفایل و کارت ملی به دسترسی دوربین نیاز است.",
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supportsRTL": true,
      "forcesRTL": true,
      "guestBaseUrl": ""
    }
  }
}
